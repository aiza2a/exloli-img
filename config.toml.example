# 日志等级
log_level = "info,sqlx=warn,teloxide=error,exloli_next=debug"

# 图片下载/上传并发基数。建议从 1–3 开始，确认图床和网络稳定后再提高。
threads_num = 3

# 自动扫描间隔，支持如 "30m"、"1h"。
interval = "1h"

# SQLite 数据库文件路径；文件不存在时会自动创建并执行迁移。
database_url = "db.sqlite"

[exhentai]
# 可访问 ExHentai 的完整 Cookie。不要提交真实 Cookie。
cookie = "ipb_member_id=...; ipb_pass_hash=...; igneous=..."

# E-Hentai 搜索参数。可按需调整类别、标签和语言。
search_params = [
  ["f_cats", "577"],
  ["f_search", "language:Chinese"]
]

# 每次扫描最多处理的画廊数。设为 0 时关闭自动扫描，但 Bot 仍会运行。
search_count = 0

# EhTagTranslation 的 db.text.json 文件路径。
trans_file = "db.text.json"

[telegraph]
# Telegraph 帐号 Access Token。不要提交真实 Token。
access_token = "..."
author_name = "exloli"
author_url = "https://t.me/your_channel"

[telegram]
# 目标频道，可填写 @频道用户名或 Telegram 数字 ID。
channel_id = "@your_channel"

# 讨论组数字 ID；用于管理员识别和评分互动。
group_id = -1000000000000

# 使用审核入群链接时自动批准成员的群组 ID；不用此功能时也填有效数字 ID。
auth_group_id = -1000000000000

# Bot 用户名，不带 @。
bot_id = "your_bot_username"

# BotFather 提供的 Bot Token。不要提交真实 Token。
token = "123456:telegram-bot-token"

[kvault]
# K-Vault 服务根地址，不要以 / 结尾。
base_url = "https://files.example.com"

# K-Vault 上传 API Token。不要提交真实 Token。
api_token = "..."

# 仅本 EXLOLI 实例的上传目录。留空时仍存放在 K-Vault 根目录。
folder_path = "EXBA"
